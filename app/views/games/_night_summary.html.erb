<% if @mafiosi_target == nil %>
  <p>The mafiosi failed to decide on a target. No one was attacked.</p>
<% elsif @doctor_saved %>
  <p><%= @mafiosi_target.display_name %> was attacked during the night but the doctor arrived in time to save them.</p>
<% else %>
  <p><%= @mafiosi_target.display_name %> was attacked and eliminated during the night. This player was a <%= Player::ROLES[@mafiosi_target.role] %></p>
<% end %>