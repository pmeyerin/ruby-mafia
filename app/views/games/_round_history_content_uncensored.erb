<%# locals: (game:, current_round:) -%>
<% game.round.filter { |round| round.round_number <  current_round.round_number}.each do |round| %>
  <hr/>
  <b>Round <%= round.round_number %></b>

  <% if round.game_phase == GAME_PHASE[:NIGHT] %>
    <% if (mafia_target = RoundService.find_mafia_target(round)) %>
      <% if RoundService.doctor_saved(round) %>
        <p><span class="player-name"><%= mafia_target.display_name %></span> was attacked during the night but <span class="player-name"><%= GameService.find_by_role(game, PLAYER_ROLE[:DOCTOR]).display_name %></span>, the doctor, arrived in time to save them.</p>
      <% else %>
        <% if (flavor_text = RoundService.generate_mafia_hit_flavor_text(round)) %>
          <%= tag.p flavor_text.html_safe %>
          <p><span class="player-name"><%= mafia_target.display_name %></span> was revealed to be a <%= Player::ROLES[mafia_target.role] %></p>
        <% else %>
          <p><span class="player-name"><%= mafia_target.display_name %></span> was attacked and eliminated during the night. This player was a <%= Player::ROLES[mafia_target.role] %></p>
        <% end %>
      <% end %>
    <% else %>
      <p>The Mafiosi failed to decide on a target. No one was attacked.</p>
    <% end %>
    <% if (detective_target = RoundService.detective_found(round)) %>
      <p><span class="player-name"><%= GameService.find_by_role(game, PLAYER_ROLE[:DETECTIVE]).display_name %></span>, the detective, identified <span class="player-name"><%= detective_target.display_name %></span> as a Mafioso and took them into custody.</p>
    <% end %>
  <% else %>
    <% if (eliminated_player = RoundService.find_eliminated_player(round)) %>
      <p>The villagers voted to eliminated <span class="player-name"><%= eliminated_player.display_name %></span>. This player was a <%= Player::ROLES[eliminated_player.role] %></p>
    <% end %>
  <% end %>
<% end %>
<hr/>