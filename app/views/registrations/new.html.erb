<h1>Sign up</h1>

<%= form_with model: @user, url: registration_path do |f| %>
  <%= tag.div(@user.errors.full_messages.to_sentence) if @user.errors.any? %>

  <div>
    <%= f.label :user_name %>
    <%= f.text_field :user_name %>
  </div>

<!--  <div>-->
    <%#= f.label "#{:email} (optional)" %>
    <%#= f.email_field :email %>
<!--  </div>-->

  <div>
    <%= f.label :password %>
    <%= f.password_field :password %>
  </div>

  <%= f.submit "Sign up" %>
<% end %>